<Window x:Class="TestAO1145WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
         xmlns:m="clr-namespace:TestAO1145WPF.Model"
         xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel" xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
        Title="Главное окно" Height="450" Width="800">
    <Window.Resources >
        <vm:MainWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" >
                    <Button Content="Окно ре-тов " HorizontalAlignment="Left" Command="{Binding OpenResultWin}" Background="White" BorderBrush="White"/>
            <Button Content=" Все тесты "  HorizontalAlignment="Left" Command="{Binding OpenAllTestWin}" Background="White" BorderBrush="White"/>
            <Button Content=" Окно профиля"  HorizontalAlignment="Left" Command="{Binding OpenStudentWin}" Background="White" BorderBrush="White"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem  Header="Преподаватели" >
                <StackPanel>
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible"
                    ItemsSource="{Binding TeacherList}" SelectedItem="{Binding Teacher}" x:Name="UserMenuLB" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                                          CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            <TabItem  Header="Студенты">
                <StackPanel>
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible"
     ItemsSource="{Binding StudentList}" SelectedItem="{Binding Student}" x:Name="UserMenuL" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                           CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Предметы">
                <StackPanel>
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible"
ItemsSource="{Binding SubjectList}" SelectedItem="{Binding Subject}" x:Name="UserMenu" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                      CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
