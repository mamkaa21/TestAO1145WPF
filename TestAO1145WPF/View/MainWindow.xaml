<Window x:Class="TestAO1145WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
         xmlns:m="clr-namespace:TestAO1145WPF.Model"
         xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel" xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
        Title="Окно студента" Height="450" Width="800" >
    <Window.Resources >
        <vm:MainWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid Background="BlanchedAlmond">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Background="PeachPuff">
            <Button Content="Окно ре-тов " HorizontalAlignment="Left" Command="{Binding OpenResultForOneStWin}" 
                    Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            <Button Content=" Все тесты "  HorizontalAlignment="Left" Command="{Binding OpenAllTestForOneStWin}" 
                    Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            <Button Content=" Окно профиля"  HorizontalAlignment="Left" Command="{Binding OpenUserStWin}" 
                    Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
        </StackPanel>
        <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="2" Background="PapayaWhip"
                    ItemsSource="{Binding TestList}" SelectedItem="{Binding Test}" x:Name="UserMenuLB" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                                          CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                        <TextBlock  Text="{Binding Name}" Foreground="#FF7F3838"/>
                        <TextBlock  Text="{Binding IdTeacherNavigation.LastName}" Foreground="#FF7F3838"/>
                                    
                        <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
               
    </Grid>
</Window>
