<Window x:Class="TestAO1145WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
         xmlns:m="clr-namespace:TestAO1145WPF.Model"
         xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel" xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
        Title="Главное меню" Height="450" Width="800" >
    <Window.Resources >
        <vm:MainWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid Background="PapayaWhip">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Background="PeachPuff">
            <Button Content=" Все тесты "  HorizontalAlignment="Left" Command="{Binding OpenAllTestForOneStWin}" 
                    Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            <Button Content=" Окно профиля"  HorizontalAlignment="Left" Command="{Binding OpenUserStWin}" 
                    Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
        </StackPanel>
        <Grid Grid.Row="1" Visibility="{Binding SelectPrepod}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock Text="Выберите преподавателя" FontSize="15" Foreground="#FF7F3838" FontFamily="Impact"/>
            <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="2" Background="PapayaWhip" Foreground="#FF7F3838"
    ItemsSource="{Binding PrepodList}" SelectedItem="{Binding Prepod}" x:Name="UserMenuLB" Height="405" FontFamily="Impact" FontSize="15" >
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                          CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ListBox.ItemTemplate >
                    <DataTemplate >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="20 0 0 0"  Text="{Binding StringFormat={}Преподаватель: {0}}" Foreground="#FF7F3838"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <Grid Grid.Row="1" Visibility="{Binding SelectTest}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="Назад" Command="{Binding Back}" Margin="5" FontFamily="Impact" FontSize="15"/>
                <TextBlock Text="Выберите тест преподавателя" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            </StackPanel>
            <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="2" Background="PapayaWhip" Foreground="#FF7F3838"
ItemsSource="{Binding TestList}" SelectedItem="{Binding Test}" x:Name="UserMenu1LB" Height="405" FontFamily="Impact" FontSize="15">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding DoubleClickCommandNext}"
                      CommandParameter="{Binding ElementName=UserMenu1LB, Path=SelectedItem}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ListBox.ItemTemplate >
                    <DataTemplate >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock  Text="{Binding Name, StringFormat={}Название теста: {0}}" Foreground="#FF7F3838"/>
                            <TextBlock Margin="20 0 0 0"  Text="{Binding Subject, StringFormat={}ПРедмет: {0}}" Foreground="#FF7F3838"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
