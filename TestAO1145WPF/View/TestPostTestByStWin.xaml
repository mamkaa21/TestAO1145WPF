<Window x:Class="TestAO1145WPF.View.TestPostTestByStWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:local="clr-namespace:TestAO1145WPF.View"
    xmlns:m="clr-namespace:TestAO1145WPF.Model"
    xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel" 
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
    mc:Ignorable="d"
    DataContext="{DynamicResource vm}"
Title="Окно теста" Height="450" Width="800" >
    <Window.Resources >
        <vm:TestPostTestByStWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid Background="PapayaWhip" >
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Background="PeachPuff" >
            <Button Content="назад " Command="{Binding Back}" 
             Background="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" BorderThickness ="0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <Label Content="Название теста" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" />
            <Label Content="{Binding Test.Name}" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" Width="250"/>
        </StackPanel>
        <ListBox ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="2" Background="PapayaWhip"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"                  
            ItemsSource="{Binding QuestionList}" SelectedItem="{Binding Question}" x:Name="UserMenuLB" >
            <ListBox.ItemTemplate >
                <DataTemplate >
                    <StackPanel >
                        <TextBlock  Text="{Binding Name}"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                        <ItemsControl Margin="20 0 0 0"  ItemsSource="{Binding Answers}"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Text}"
                                      IsChecked="{Binding IsChecked}" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Завершить" Command="{Binding Post}" Grid.Row="3" HorizontalAlignment="Center"
       Background="{x:Null}" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" BorderBrush="{x:Null}"/>
    </Grid>
</Window>
