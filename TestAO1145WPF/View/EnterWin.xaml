<Window x:Class="TestAO1145WPF.View.EnterWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
        xmlns:m="clr-namespace:TestAO1145WPF.Model"
        xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
        Title="Окно входа" Height="450" Width="800">
    <Window.Resources>
        <vm:EnterWinVM x:Key ="vm"/>
    </Window.Resources>
    <Grid Background="BlanchedAlmond" Cursor="">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Grid.Column="1" Grid.Row="2" Content="Логин"  HorizontalAlignment="Right" 
               VerticalAlignment="Center" FontFamily="Impact" FontSize="25" Foreground="#FF7F3838"/>
        <TextBox Text="{Binding Student.Login}" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="2" Margin="0 20 0 20" 
                 FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
        <Label Grid.Column="1" Grid.Row="3"  Content="Пароль"  FontFamily="Impact" FontSize="24" 
               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#FF7F3838" />
        <TextBox Text="{Binding Student.Password}" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Margin="0 20 0 20" 
                 FontFamily="Impact" FontSize="25" Foreground="#FF7F3838" >
        </TextBox>
        <!--<PasswordBox x:Name="passwordBox" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Margin="0 20 0 20" />-->
        <Button Grid.Column="2" Grid.Row="5" Grid.ColumnSpan="2" Content="Войти" Margin="10" Command="{Binding Enter}"
                FontFamily="Impact" FontSize="30" Foreground="#FF7F3838" Background="BlanchedAlmond" BorderBrush="BlanchedAlmond"/>
    </Grid>
</Window>
