<Window x:Class="TestAO1145WPF.View.EnterWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
        xmlns:m="clr-namespace:TestAO1145WPF.Model"
        xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
        Title="Окно входа" Height="450" Width="800">
    <Window.Resources>
        <vm:EnterWinVM x:Key ="vm"/>
    </Window.Resources>
    <Grid Background="#FFF9EB" Cursor="">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Grid.Column="1"  Content="Добро пожаловать в ITest📑"  Grid.ColumnSpan="4" HorizontalAlignment="Center"
               VerticalAlignment="Center" FontFamily="Roboto" FontSize="30" Foreground="#FF68827A" FontWeight="Bold"/>
        <Label Grid.Column="1" Grid.Row="2" Content="Логин"  HorizontalAlignment="Right" FontWeight="DemiBold"
               VerticalAlignment="Center" FontFamily="Roboto" FontSize="25" Foreground="#FF68827A"/>
        <TextBox Text="{Binding Student.Login}" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="2" Margin="0 20 0 20" FontWeight="DemiBold"
                 FontFamily="Roboto" FontSize="15" Foreground="#FF68827A"/>
        <Label Grid.Column="1" Grid.Row="3"  Content="Пароль"  FontFamily="Roboto" FontSize="24" FontWeight="DemiBold"
               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#FF68827A" />
        <PasswordBox x:Name="passwordBox" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Margin="0 20 0 20" FontWeight="DemiBold"
                 FontFamily="Roboto" FontSize="13" Foreground="#FF68827A" >
        </PasswordBox>
        <Button Grid.Column="2" Grid.Row="5" Grid.ColumnSpan="2" Content="Войти" Margin="10" Command="{Binding Enter}" FontWeight="DemiBold"
                FontFamily="Roboto" FontSize="25" Foreground="#FF68827A" Background="#FFF9EB" BorderBrush="{x:Null}"/>
    </Grid>
</Window>
