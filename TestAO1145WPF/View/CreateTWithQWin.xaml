<Window x:Class="TestAO1145WPF.View.CreateTWithQWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:TestAO1145WPF.View"
        xmlns:m="clr-namespace:TestAO1145WPF.Model"
        xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"     
        mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
    Title="Окно редактирования тестов" Height="450" Width="800">
    <Window.Resources >
        <vm:CreateTWithQWinVM x:Key ="vm"/>
        <ControlTemplate x:Key="TemplateOneAnswer" >
            <StackPanel >
                <Label Content="Вы можете выбрать один правильный вариант ответа" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Answers}" HorizontalContentAlignment="Stretch" MaxHeight="150" BorderBrush="#FF7F3838" BorderThickness="0 2 0 2 "
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" Background="#FFFDF5DE">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Tag="{Binding}" IsChecked="{Binding RightAnswer}" Checked="OneAnswer_Checked" ToolTip="Верный ответ" 
                                                 Foreground="#FF7F3838" Background="#FFFDF5DE" BorderBrush="#FF7F3838"/>
                                    <TextBox Text="{Binding Text}" Grid.Column="1" FontSize="15" Foreground="#FF7F3838" BorderBrush="{x:Null}"/>
                                    <Button Content="❌" Foreground="#FF7F3838" Background="#FFFDF5DE"  BorderBrush="{x:Null}"
                                        Command="{Binding RemoveAnswer}" CommandParameter="{Binding}"
                                        Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button  Content="Добавить ответ" Grid.Row="1" Command="{Binding AddAnswer}" DataContext="{StaticResource vm}" BorderBrush="{x:Null}"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" Background="#FFFDF5DE" />
                    <Button  Content="Сохранить вопрос" Grid.Row="2" Command="{Binding SaveQuestion}" DataContext="{StaticResource vm}" BorderBrush="{x:Null}"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" Background="#FFFDF5DE"/>
                </Grid>
            </StackPanel>
        </ControlTemplate>
        <ControlTemplate x:Key="TemplateManyAnswer">
            <StackPanel>
                <Label Content="Вы можете выбрать несколько правильных вариантов ответа" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Answers}" HorizontalContentAlignment="Stretch" MaxHeight="150" BorderBrush="#FF7F3838" BorderThickness="0 2 0 2 "
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Tag="{Binding}" IsChecked="{Binding RightAnswer}" ToolTip="Верный ответ"
                                              Foreground="#FF7F3838" Background="#FFFDF5DE" BorderBrush="#FF7F3838"/>
                                    <TextBox Text="{Binding Text}" Grid.Column="1"  FontSize="15" Foreground="#FF7F3838" BorderBrush="{x:Null}"/>
                                    <Button Content="❌" Foreground="#FF7F3838" Background="#FFFDF5DE"  BorderBrush="{x:Null}"
                            Command="{Binding RemoveAnswer}" CommandParameter="{Binding}"
                            Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button  Content="Добавить ответ" Grid.Row="1" Command="{Binding AddAnswer}" DataContext="{StaticResource vm}" Background="#FFFDF5DE"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                    <Button  Content="Сохранить вопрос" Grid.Row="2" Command="{Binding SaveQuestion}" DataContext="{StaticResource vm}" Background="#FFFDF5DE"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                </Grid>
            </StackPanel>
        </ControlTemplate>
        <ControlTemplate x:Key="TemplateHandAnswer">
            <StackPanel>
                <Label Content="Вы можете указать несколько вариаций правильного ответа" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Answers}" HorizontalContentAlignment="Stretch" MaxHeight="150" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Text}" FontSize="15" Foreground="#FF7F3838" BorderBrush="{x:Null}"/>
                                    <Button Content="❌" Foreground="#FF7F3838" Background="#FFFDF5DE"  BorderBrush="{x:Null}"
                    Command="{Binding RemoveAnswer}" CommandParameter="{Binding}"
                    Grid.Column="1"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button  Content="Добавить ответ" Grid.Row="1" Command="{Binding AddAnswer}" DataContext="{StaticResource vm}" Background="#FFFDF5DE"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                    <Button  Content="Сохранить вопрос" Grid.Row="2" Command="{Binding SaveQuestion}" DataContext="{StaticResource vm}" Background="#FFFDF5DE"
                             FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                </Grid>
            </StackPanel>
        </ControlTemplate>
    </Window.Resources >
    <Grid  Background="PeachPuff">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Button Content="   Назад   " HorizontalAlignment="Left" Command="{Binding Back}"  
          Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
        <StackPanel Grid.Row="1" Background="PeachPuff">
            <Label Content="Тест"  Foreground="#FF7F3838" FontFamily="Impact" FontSize="15"/>
            <Label Content="{Binding Test.Name}" FontFamily="Impact" FontSize="15"
                 Foreground="#FF7F3838"  Background="PeachPuff" Height="20" BorderBrush="#FF7F3838" BorderThickness="0 0 0 2"/>
        </StackPanel>
        <Grid Grid.Row="2"  Background="PapayaWhip">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition  Width="600"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <Menu  Background="PapayaWhip" Width="200">
                <MenuItem Header="➕ Тип вопроса" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" >
                    <MenuItem Header="Один правильный ответ" Command="{Binding OneAnswer}"/>
                    <MenuItem Header="Несколько правильных ответов" Command="{Binding ManyAnswer}"/>
                    <MenuItem Header="Ручной ввод ответа"  Command="{Binding HandAnswer}"/>
                </MenuItem>
            </Menu>
            <ListBox  ItemsSource="{Binding Questions}" SelectedItem="{Binding Question}" Grid.Row="1" DisplayMemberPath="NameSlice" 
                     Background="PapayaWhip" BorderBrush="#FF7F3838" Foreground="#FF7F3838" BorderThickness="0 0 2 0" FontFamily="Impact"/>
            <Label Content="Текст вопроса:" Grid.Column="1" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"  Background="PapayaWhip" >
                <TextBox TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"  Background="White"
                         FontFamily="Impact" FontSize="10" Foreground="#FF7F3838" BorderBrush="#FF7F3838"
                         MinLines="5" MaxLines="20" Text="{Binding Question.Name}"/>
                <ItemsControl DataContext="{Binding Question}" x:Name="answersControl"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
