<Window x:Class="TestAO1145WPF.View.TeacherWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestAO1145WPF.View"
  xmlns:m="clr-namespace:TestAO1145WPF.Model"
  xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        mc:Ignorable="d"
          DataContext="{DynamicResource vm}"
    Title="Окно учителя" Height="450" Width="800">
    <Window.Resources >
        <vm:TeacherWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="Окно рез-тов тестов" Command="{Binding OpenResultWin}"/>
            <MenuItem Header="Все тесты" Command="{Binding OpenAllTestWin}" />
            <MenuItem Header="Окно профиля" Command="{Binding OpenStudentWin}"/>
            <MenuItem Header="Создать тест" Command="{Binding OpenStudentWin}"/>
        </Menu>
        <ListBox Grid.Row="1" Grid.ColumnSpan="6"  Grid.RowSpan="6" ScrollViewer.VerticalScrollBarVisibility="Visible"
             ItemsSource="{Binding TestList}" SelectedItem="{Binding Test}" x:Name="UserMenuLB">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                                            CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                    <!--тут ничего не трогать!!!-->
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate >
                <DataTemplate >
                    <StackPanel Width="200">
                        <TextBlock  Text="{Binding Name}"/>


                        <!--тут дальше все айди я хз как вытануть-->

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
