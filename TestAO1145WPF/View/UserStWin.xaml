<Window x:Class="TestAO1145WPF.View.UserStWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:local="clr-namespace:TestAO1145WPF.View"
xmlns:m="clr-namespace:TestAO1145WPF.Model"
xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
        mc:Ignorable="d"
               DataContext="{DynamicResource vm}"
Title="Окно профиля" Height="450" Width="800">
    <Window.Resources >
        <vm:UserStWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid Background="PapayaWhip">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="150"/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="4"  Background="PeachPuff" >
                <Button Content="назад " Command="{Binding Back}" 
                        Background="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" BorderThickness ="0"/>
                <Button Content="Окно ре-тов " Command="{Binding OpenResultWin}"  
                        Background="PeachPuff"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" BorderThickness ="0"/>
                <Button Content=" Все тесты " Command="{Binding OpenAllTestWin}"  
                        Background="PeachPuff"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" BorderThickness ="0"/>
            </StackPanel>
            
            <Label Content="Студент " FontFamily="Impact" FontSize="20" Foreground="#FF7F3838"  Grid.Row="2"  />
            <TextBox Text="{Binding Student.LastName}" Background="PapayaWhip"
                     BorderThickness="0 0 0 2" BorderBrush="#FF7F3838"   IsEnabled="{Binding ListBoxEnabled}" Grid.Row="2" Grid.Column="1" 
              Height="30" VerticalAlignment="Top"/>
            <TextBox Text="{Binding Student.FirstName}"  Background="PapayaWhip"
                     BorderThickness="0 0 0 2" BorderBrush="#FF7F3838"   IsEnabled="{Binding ListBoxEnabled}" Grid.Row="2" Grid.Column="2" 
              Height="30" VerticalAlignment="Top"/>
            <Label Content="Группа "  FontFamily="Impact" FontSize="20" Foreground="#FF7F3838"  Grid.Row="3"  />
            <TextBox Text="{Binding Student.IdClass}" BorderThickness="0 0 0 2" BorderBrush="#FF7F3838"
                     Background="PapayaWhip"  IsEnabled="{Binding ListBoxEnabled}" Grid.Row="3" Grid.Column="1" 
              Height="30" VerticalAlignment="Top"/>
            <!-- как-то вытянуть класс ученика -->         
        </Grid>
    </Grid>
</Window>
