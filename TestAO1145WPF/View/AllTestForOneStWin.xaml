<Window x:Class="TestAO1145WPF.View.AllTestForOneStWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:TestAO1145WPF.View"
        xmlns:m="clr-namespace:TestAO1145WPF.Model"
        xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
      mc:Ignorable="d"
        DataContext="{DynamicResource vm}"
  Title="Окно всех тестов" Height="450" Width="800">
    <Window.Resources >
        <vm:AllTestForOneStWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid Background="PapayaWhip">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Background="PeachPuff">
            <Button Content="Назад" Command="{Binding Back}" 
                Background="PeachPuff" BorderThickness="0"  FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
            <Button Content=" Окно профиля"  HorizontalAlignment="Left" Command="{Binding OpenUserStWin}" 
         Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
        </StackPanel>
        <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible" Background="BlanchedAlmond" 
 ItemsSource="{Binding StudentanswerList}" SelectedItem="{Binding Studentanswer}" x:Name="UserMenuL" Height="405" Grid.Row="2" BorderBrush="{x:Null}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                       CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <ListBox.ItemTemplate >
                <DataTemplate >
                    <StackPanel Orientation="Horizontal" Width="800">
                        <TextBlock  Text="{Binding StudentName, StringFormat={}Студент: Имя {0}}" Foreground="#FF7F3838"/>
                        <TextBlock Margin="20 0 0 0"  Text="{Binding StudentLastName, StringFormat={}Фамилия {0}}" Foreground="#FF7F3838"/>
                        <TextBlock Margin="20 0 0 0"  Text="{Binding Test, StringFormat={}Название теста: {0}}" Foreground="#FF7F3838"/>
                        <TextBlock Margin="20 0 0 0"  Text="{Binding Mark, StringFormat={}Оценка: {0}}" Foreground="#FF7F3838" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
