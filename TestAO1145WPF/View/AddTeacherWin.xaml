<Window x:Class="TestAO1145WPF.View.AddTeacherWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:local="clr-namespace:TestAO1145WPF.View"
xmlns:m="clr-namespace:TestAO1145WPF.Model"
xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors"     
        mc:Ignorable="d"
              DataContext="{DynamicResource vm}"
    Title="Главное окно" Height="450" Width="800">
    <Window.Resources >
        <vm:AddTeacherWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Menu Background="PeachPuff">
            <MenuItem Header="Создать" 
               BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                <MenuItem Header="Добавить" Command="{Binding OpenAddTeacher}"  
                  Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                <!--<MenuItem Header="Изменить" Command="{Binding OpenAddStudent}"/>
        <MenuItem Header="Изменить" Command="{Binding OpenAddSubject}"/>-->
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1" Grid.ColumnSpan="7" Grid.RowSpan="7">
            <TabItem  Header="Преподаватели">
                <StackPanel >
                    <Label Content="Фамилия"/>
                    <TextBox Text="{Binding Teacher.LastName}" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="Black"/>
                    <Label Content="Имя" Grid.Row="1"/>
                    <TextBox Text="{Binding Teacher.FirstName}" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" BorderBrush="Black"/>
                    <Label Content="Предмет" Grid.Row="3"/>
                    <ComboBox ItemsSource="{Binding SubjectList}" SelectedItem="{Binding Subject}" DisplayMemberPath="{Binding Subject.Name}" 
                               Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3"/>
                    <!--SelectedValuePath="{Binding Good.Category}"-->
                    <ComboBox ItemsSource="{Binding SubjectList}" SelectedItem="{Binding Subject}" DisplayMemberPath="{Binding Subject.Name}" 
                            Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3"/>

                    <Button Grid.Column="1" Grid.Row="5"  Content="добавить" Command="{Binding AddTea}"/>
                    <Button Grid.Column="2" Grid.Row="5"  Content="обновить" Command="{Binding EditTea}"/>
                </StackPanel>


            </TabItem>
            <TabItem  Header="Студенты">
                <StackPanel >
                    <Label Content="Фамилия"/>
                    <TextBox Text="{Binding Teacher.LastName}" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="Black"/>
                    <Label Content="Имя" Grid.Row="1"/>
                    <TextBox Text="{Binding Teacher.FirstName}" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" BorderBrush="Black"/>
                    <Label Content="Группа" Grid.Row="3"/>
                    <!--<ComboBox ItemsSource="{Binding SubjectList}" SelectedItem="{Binding Subject}" DisplayMemberPath="{Binding Subject.Name}" 
                               Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3"/>-->
                    <!--SelectedValuePath="{Binding Good.Category}"-->                  
                    <Button Grid.Column="1" Grid.Row="5"  Content="добавить" Command="{Binding AddTea}"/>
                    <Button Grid.Column="2" Grid.Row="5"  Content="обновить" Command="{Binding EditTea}"/>
                </StackPanel>
            </TabItem>
            <TabItem  Header="Предмет">

                <StackPanel>
                     <Label Content="Название"/>
                    <TextBox Text="{Binding Good.Title}" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="Black"/>

                    <Button Grid.Column="1" Grid.Row="5"  Content="добавить" Command="{Binding AddCategories}"/>
                    <Button Grid.Column="2" Grid.Row="5"  Content="обновить" Command="{Binding EditCategories}"/>
                
                </StackPanel>
                   
            </TabItem>
            <TabItem  Header="Сотрудники">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Имя"/>
                    <TextBox Text="{Binding User.Name}" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="Black"/>
                    <Label Content="Логин" Grid.Row="1"/>
                    <TextBox Text="{Binding User.Login}" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" BorderBrush="Black"/>
                    <Label Content="Пароль" Grid.Row="2"/>
                    <TextBox Text="{Binding User.Password}" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" BorderBrush="Black"/>

                    <Button Grid.Column="1" Grid.Row="5"  Content="добавить" Command="{Binding AddUsers}"/>
                    <Button Grid.Column="2" Grid.Row="5"  Content="обновить" Command="{Binding EditUsers}"/>
                </Grid>
            </TabItem>
        </TabControl>


    </Grid>
</Window>
