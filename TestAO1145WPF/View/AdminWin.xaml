<Window x:Class="TestAO1145WPF.View.AdminWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TestAO1145WPF.View"
xmlns:m="clr-namespace:TestAO1145WPF.Model"
xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors"     
        mc:Ignorable="d"
              DataContext="{DynamicResource vm}"
    Title="Главное окно" Height="450" Width="800">
    <Window.Resources >
        <vm:AdminWinVM x:Key ="vm"/>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <!-- Border — это сама "шапка" вкладки -->
                        <Border Name="Border"  
                            SnapsToDevicePixels="True">
                            <!-- Текст внутри вкладки -->
                            <ContentPresenter x:Name="ContentSite"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ContentSource="Header"
                                          Margin="12,2,12,2"
                                          RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- КОГДА ВКЛАДКА ВЫБРАНА -->
                            <Trigger Property="IsSelected" Value="True">
                                <!-- Здесь меняем цвет фона на тот же, что и у панели (или другой) -->
                                <Setter TargetName="Border" Property="Background" Value="#FFDAB9"/>
                            </Trigger>
                            <!-- КОГДА МЫШКА НАВЕДЕНА (Hover) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFCC99"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources >
    <Grid Background="PeachPuff">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Menu Background="PeachPuff">
            <MenuItem Header="Создать" 
                       BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                <MenuItem Header="Добавить" Command="{Binding OpenAddTeacher}"  
                          Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838"/>
                <!--<MenuItem Header="Изменить" Command="{Binding OpenAddStudent}"/>
                <MenuItem Header="Изменить" Command="{Binding OpenAddSubject}"/>-->
            </MenuItem>
            <MenuItem Header="Удалить" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                <MenuItem Header="Добавить" Command="{Binding OpenDelete}" />
                <!--<MenuItem Header="Изменить" Command="{Binding OpenDeleteT}"/>
                <MenuItem Header="Изменить" Command="{Binding OpenDeleteSt}"/>-->
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1" Background="PeachPuff" Grid.ColumnSpan="4">
            <TabItem  Header="Преподаватели"  Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838" OpacityMask="Black">
                <StackPanel >
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible" Background="PapayaWhip"
                    ItemsSource="{Binding TeacherList}" SelectedItem="{Binding Teacher}" x:Name="UserMenuLB" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                                          CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            <TabItem  Header="Студенты"  Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                <StackPanel>
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible"
     ItemsSource="{Binding StudentList}" SelectedItem="{Binding Student}" x:Name="UserMenuL" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                           CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Предметы"  Background="PeachPuff" BorderBrush="PeachPuff" FontFamily="Impact" FontSize="15" Foreground="#FF7F3838">
                <StackPanel>
                    <ListBox  ScrollViewer.VerticalScrollBarVisibility="Visible"
ItemsSource="{Binding SubjectList}" SelectedItem="{Binding Subject}" x:Name="UserMenu" Height="405">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DoubleClickCommand}"
                      CommandParameter="{Binding ElementName=UserMenuLB, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                                <!--тут ничего не трогать!!!-->
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate >
                            <DataTemplate >
                                <StackPanel >
                                    <TextBlock  Text="{Binding FirstName}"/>
                                    <TextBlock  Text="{Binding LastName}"/>


                                    <!--тут дальше все айди я хз как вытануть-->

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
        </TabControl>
       
       
    </Grid>
</Window>
