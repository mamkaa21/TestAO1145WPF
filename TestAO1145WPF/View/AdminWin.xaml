<Window x:Class="TestAO1145WPF.View.AdminWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TestAO1145WPF.View"
xmlns:m="clr-namespace:TestAO1145WPF.Model"
xmlns:vm ="clr-namespace:TestAO1145WPF.ViewModel"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        mc:Ignorable="d"
        mc:Ignorable="d"
              DataContext="{DynamicResource vm}"
    Title="Главное окно" Height="450" Width="800">
    <Window.Resources >
        <vm:AdminWinVM x:Key ="vm"/>
    </Window.Resources >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="Преподавателя">
                <MenuItem Header="Добавить" Command="{Binding OpenAddNewTeacher}" />
                <MenuItem Header="Изменить" Command="{Binding OpenEditTeacher}"/>
            </MenuItem>
            <MenuItem Header="Студенты">
                <MenuItem Header="Добавить" Command="{Binding OpenAddNewStudent}" />
                <MenuItem Header="Изменить" Command="{Binding OpenEditStudent}"/>
            </MenuItem>
            <MenuItem Header="Предметы">
                <MenuItem Header="Добавить" Command="{Binding OpenAddNewSubject}" />
                <MenuItem Header="Изменить" Command="{Binding OpenEditSubject}"/>
            </MenuItem>
        </Menu>
    </Grid>
</Window>
